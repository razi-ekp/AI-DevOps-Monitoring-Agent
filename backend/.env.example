# Copy this to .env and fill in your values
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
SIMULATOR_TICK_SECONDS=1.5
SIMULATOR_LOG_EVERY_N_TICKS=3
SIMULATOR_INCIDENT_PROBABILITY=0.18
USE_REAL_METRICS=false
USE_REAL_LOGS=false
PROMETHEUS_URL=http://localhost:9090
LOKI_URL=http://localhost:3100
LOKI_QUERY={job="varlogs"}
LOKI_LABEL_SERVICE_KEY=app
REAL_METRICS_TIMEOUT_SECONDS=10
REAL_LOGS_TIMEOUT_SECONDS=10
INCIDENT_ERROR_BURST_COUNT=3
INCIDENT_ERROR_BURST_WINDOW_SECONDS=300
INCIDENT_COOLDOWN_SECONDS=300
USE_REAL_AUTOHEAL=false
AUTOHEAL_EXECUTOR=dry-run
AUTOHEAL_DRY_RUN=true
AUTOHEAL_NAMESPACE=default
AUTOHEAL_KUBECTL_PATH=kubectl
AUTOHEAL_SCALE_REPLICAS=3
AUTOHEAL_COOLDOWN_SECONDS=180
AUTOHEAL_MAX_ACTIONS_PER_HOUR=20
AUTOHEAL_SERVICE_ALLOWLIST=

# Optional Slack webhook for real alert delivery
SLACK_WEBHOOK_URL=

# Optional SMTP for email alerts
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_TO=
